<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link href="https://fonts.googleapis.com/css2?family=Syncopate:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <link rel="stylesheet" href="/style.css">
    <style>
        .modal { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.9); z-index: 1000; padding: 40px 20px;}
        .modal-content { max-width: 400px; margin: 0 auto; border: 1px solid #333; padding: 30px; background: #000; }
        .modal input { width: 100%; background: transparent; border: none; border-bottom: 1px solid #666; color: #fff; padding: 10px 0; margin-bottom: 20px; outline: none; font-size: 12px; text-transform: uppercase;}
        .success-overlay { display: none; position: fixed; inset: 0; background: #000; z-index: 2000; flex-direction: column; justify-content: center; align-items: center; }
        .tick-icon { font-size: 80px; color: #fff; animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; opacity: 0; transform: scale(0.5); }
        .success-text { font-family: 'Syncopate', sans-serif; margin-top: 20px; letter-spacing: 4px; font-size: 14px; opacity: 0; animation: fadeIn 0.5s ease 0.3s forwards; }
        @keyframes popIn { to { opacity: 1; transform: scale(1); } }
        @keyframes fadeIn { to { opacity: 1; } }
        #preloader { position: fixed; inset: 0; background: #000; z-index: 9999; display: flex; justify-content: center; align-items: center; transition: 0.8s; }
        body.loaded #preloader { opacity: 0; visibility: hidden; }
    </style>
</head>
<body>
    <div id="preloader"><div style="color:#fff; font-family:'Syncopate'; font-weight:700; letter-spacing:10px;">RETROO</div></div>

    <div class="success-overlay" id="success-overlay">
        <i class="ph-thin ph-check-circle tick-icon"></i>
        <div class="success-text">ORDER PLACED</div>
    </div>

    <div class="modal" id="checkout-modal">
        <div class="modal-content">
            <div style="display:flex; justify-content:space-between; margin-bottom: 30px;">
                <h2 style="font-family:'Syncopate'; font-size: 14px; letter-spacing:3px;">SHIPPING</h2>
                <i class="ph-thin ph-x" style="font-size:24px; cursor:pointer;" onclick="document.getElementById('checkout-modal').style.display='none'"></i>
            </div>
            <input type="text" placeholder="FULL NAME" required>
            <input type="text" id="address-input" placeholder="FULL DELIVERY ADDRESS" required>
            <input type="tel" placeholder="PHONE NUMBER" required>
            <button class="btn" style="width:100%; background:#fff; color:#000; margin-top:10px;" onclick="retrooDB.placeOrder()">CONFIRM & PAY</button>
        </div>
    </div>

    <nav class="navbar">
        <div class="nav-left"><a href="/"><i class="ph-thin ph-house"></i></a></div>
        <div class="logo">RETROO</div>
        <div class="nav-right">
            <a href="/orderhistory"><i class="ph-thin ph-user"></i></a>
            <a href="/wishlist"><i class="ph-thin ph-heart"></i></a>
            <a href="/cart"><i class="ph-fill ph-shopping-bag"></i></a>
        </div>
    </nav>

    <div style="padding: 30px 20px; max-width: 600px; margin: 0 auto;">
        <h1 style="font-family:'Syncopate'; font-size: 16px; letter-spacing:4px; text-transform:uppercase; margin-bottom: 30px; text-align:center;">Your Cart</h1>
        <div id="cart-container"></div>
    </div>

    <script src="/products.js" charset="UTF-8" defer></script>
    <script>window.addEventListener('load', () => setTimeout(() => document.body.classList.add('loaded'), 500));</script>
</body>
</html>
